# ==========================================
# HomeServer v1.0.0
# Environment Configuration Example
# ==========================================

# Docker Compose Project Name
PROJECT_NAME=homeserver

# ==========================
# MariaDB
# ==========================
MYSQL_DATABASE=homeserver
MYSQL_USER=homeserver
MYSQL_PASSWORD=your_password
MYSQL_ROOT_PASSWORD=your_root_password

# ==========================
# Redis
# ==========================
REDIS_PORT=6379

# ==========================
# FastAPI
# ==========================
FASTAPI_PORT=8000

# ==========================
# Nginx
# ==========================
NGINX_PORT=80
